datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CASHIER
  @@map("user_role")
}

enum SupplyStatus {
  OK
  LOW
  OUT
  @@map("supply_status")
}

enum PaymentMethod {
  CASH
  CARD
  @@map("payment_method")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password_hash String
  name       String
  role       Role     @default(CASHIER)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz
  sales      Sale[]

  @@map("users")
}

model Category {
  id            Int       @id @default(autoincrement())
  name       String    @unique
  display_order Int     @default(0)
  created_at    DateTime  @default(now()) @db.Timestamptz
  products   Product[]

  @@map("categories")
}

model Supply {
  id                 Int          @id @default(autoincrement())
  name               String       @unique
  unit               String       @default("unidad")
  current_stock      Decimal      @default(0) @db.Decimal(10, 2)
  min_stock          Int          @default(4)
  status             SupplyStatus @default(OK)
  last_alert_sent    DateTime?    @db.Timestamptz
  created_at         DateTime     @default(now()) @db.Timestamptz
  updated_at         DateTime     @default(now()) @updatedAt @db.Timestamptz
  recipe_items       RecipeItem[]
  alert_logs         AlertLog[]

  @@index([status], map: "idx_supplies_status")
  @@map("supplies")
}

model Product {
  id           Int          @id @default(autoincrement())
  name         String
  price        Decimal      @db.Decimal(10, 2)
  category_id  Int?
  category     Category?    @relation(fields: [category_id], references: [id], onDelete: SetNull)
  is_active    Boolean      @default(true)
  image_url    String?
  created_at   DateTime     @default(now()) @db.Timestamptz
  updated_at   DateTime     @default(now()) @updatedAt @db.Timestamptz
  recipe_items RecipeItem[]
  sale_items   SaleItem[]

  @@index([category_id], map: "idx_products_category")
  @@index([is_active], map: "idx_products_active")
  @@map("products")
}

model RecipeItem {
  id         Int     @id @default(autoincrement())
  product_id Int
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  supply_id  Int
  supply     Supply  @relation(fields: [supply_id], references: [id], onDelete: Cascade)
  quantity   Decimal @db.Decimal(10, 3)

  @@unique([product_id, supply_id])
  @@index([product_id], map: "idx_recipe_items_product")
  @@index([supply_id], map: "idx_recipe_items_supply")
  @@map("recipe_items")
}

model Sale {
  id             Int           @id @default(autoincrement())
  total          Decimal       @db.Decimal(10, 2)
  payment_method PaymentMethod
  user_id        Int?
  notes          String?
  user           User?         @relation(fields: [user_id], references: [id], onDelete: SetNull)
  created_at     DateTime      @default(now()) @db.Timestamptz
  sale_items     SaleItem[]

  @@index([user_id], map: "idx_sales_user")
  @@index([created_at], map: "idx_sales_created")
  @@map("sales")
}

model SaleItem {
  id         Int      @id @default(autoincrement())
  sale_id    Int
  sale       Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product_id Int?
  product    Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  product_name String
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)

  @@index([sale_id], map: "idx_sale_items_sale")
  @@map("sale_items")
}

model AlertLog {
  id        Int      @id @default(autoincrement())
  supply_id Int
  supply    Supply   @relation(fields: [supply_id], references: [id], onDelete: Cascade)
  message   String
  sent_at   DateTime @default(now()) @db.Timestamptz

  @@map("alert_logs")
}
